<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:keyWidth="10%p"
    app:keyHeight="48dp"
    app:keyHorizontalGap="1dp"
    app:keyVerticalGap="1dp">

    <Row>
        <Key app:codes="49"  app:keyLabel="1" app:keyEdgeFlags="4"/>
        <Key app:codes="50"  app:keyLabel="2"/>
        <Key app:codes="51"  app:keyLabel="3"/>
        <Key app:codes="52"  app:keyLabel="4"/>
        <Key app:codes="53"  app:keyLabel="5"/>
        <Key app:codes="54"  app:keyLabel="6"/>
        <Key app:codes="55"  app:keyLabel="7"/>
        <Key app:codes="56"  app:keyLabel="8"/>
        <Key app:codes="57"  app:keyLabel="9"/>
        <Key app:codes="48"  app:keyLabel="0" app:keyEdgeFlags="2"/>
    </Row>

    <Row>
        <Key app:codes="64"  app:keyLabel="@" app:keyEdgeFlags="1"/>
        <Key app:codes="35"  app:keyLabel="#"/>
        <Key app:codes="36"  app:keyLabel="$"/>
        <Key app:codes="37"  app:keyLabel="%"/>
        <Key app:codes="38"  app:keyLabel="&amp;"/>
        <Key app:codes="45"  app:keyLabel="-"/>
        <Key app:codes="43"  app:keyLabel="+"/>
        <Key app:codes="40"  app:keyLabel="("/>
        <Key app:codes="41"  app:keyLabel=")"/>
        <Key app:codes="47"  app:keyLabel="/" app:keyEdgeFlags="2"/>
    </Row>

    <Row>
        <Key app:codes="33"  app:keyLabel="!" app:keyWidth="11%p" app:keyEdgeFlags="1"/>
        <Key app:codes="34"  app:keyLabel="&quot;"/>
        <Key app:codes="39"  app:keyLabel="'"/>
        <Key app:codes="58"  app:keyLabel=":"/>
        <Key app:codes="59"  app:keyLabel=";"/>
        <Key app:codes="47"  app:keyLabel="/"/>
        <Key app:codes="63"  app:keyLabel="@string/label_question"/>
        <Key app:codes="126" app:keyLabel="~"/>
        <Key app:codes="96"  app:keyLabel="`" app:keyWidth="11%p" app:keyEdgeFlags="2"/>
    </Row>

    <Row>
        <Key app:codes="-8"  app:keyLabel="ABC" app:keyWidth="14%p" app:keyEdgeFlags="1"/>
        <Key app:codes="92"  app:keyLabel="\\"/>
        <Key app:codes="124" app:keyLabel="|"/>
        <Key app:codes="60"  app:keyLabel="&lt;"/>
        <Key app:codes="62"  app:keyLabel="&gt;"/>
        <Key app:codes="123" app:keyLabel="{"/>
        <Key app:codes="125" app:keyLabel="}"/>
        <Key app:codes="-5"  app:keyLabel="⌫" app:keyWidth="14%p" app:isRepeatable="true" app:keyEdgeFlags="2"/>
    </Row>

    <Row>
        <Key app:codes="-2"  app:keyLabel="@string/label_symbols" app:keyWidth="14%p" app:keyEdgeFlags="1"/>
        <Key app:codes="44"  app:keyLabel=","/>
        <Key app:codes="32"  app:keyLabel="" app:keyWidth="42%p"/>
        <Key app:codes="46"  app:keyLabel="."/>
        <Key app:codes="-4"  app:keyLabel="⏎" app:keyWidth="14%p" app:keyEdgeFlags="2"/>
    </Row>

</Keyboard>
