<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/qwerty_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1e1e1e">

    <!-- SUGGESTION ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/btn_clipboard"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="⧉"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:background="@drawable/key_bg_dark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:gravity="center_vertical">

            <TextView android:id="@+id/sug1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/key_bg_dark"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:layout_marginEnd="3dp" />

            <TextView android:id="@+id/sug2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/key_bg_dark"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:layout_marginEnd="3dp" />

            <TextView android:id="@+id/sug3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/key_bg_dark"
                android:textColor="#ffffff"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_tools"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✎"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:background="@drawable/key_bg_dark" />

    </LinearLayout>

    <!-- NUMBER ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView android:id="@+id/k1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="1" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="2" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="3" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="4" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="5" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="6" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="7" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="8" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="9" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/k0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="0" android:textColor="#fff" android:textSize="15sp" android:background="@drawable/key_bg"/>
    </LinearLayout>

    <!-- QWERTY ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView android:id="@+id/kq" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="q" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kw" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="w" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/ke" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="e" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kr" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="r" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kt" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="t" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/ky" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="y" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/ku" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="u" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/ki" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="i" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/ko" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="o" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kp" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="p" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg"/>
    </LinearLayout>

    <!-- ASDF ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:gravity="center_horizontal">
        <Space android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.5"/>
        <TextView android:id="@+id/ka" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="a" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/ks" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="s" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kd" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="d" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kf" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="f" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kg" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="g" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kh" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="h" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kj" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="j" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kk" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="k" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kl" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="l" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg"/>
        <Space android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.5"/>
    </LinearLayout>

    <!-- ZXCV ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView android:id="@+id/btn_shift" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.4" android:gravity="center" android:text="⇧" android:textColor="#fff" android:textSize="18sp" android:background="@drawable/key_bg_dark" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kz" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="z" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kx" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="x" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kc" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="c" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kv" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="v" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kb" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="b" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/kn" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="n" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/km" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="m" android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/btn_backspace" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.4" android:gravity="center" android:text="⌫" android:textColor="#fff" android:textSize="18sp" android:background="@drawable/key_bg_dark"/>
    </LinearLayout>

    <!-- ACTION ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        <TextView android:id="@+id/btn_symbols" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.3" android:gravity="center" android:text="\?123" android:textColor="#fff" android:textSize="13sp" android:background="@drawable/key_bg_dark" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/btn_emoji" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="☺" android:textColor="#fff" android:textSize="18sp" android:background="@drawable/key_bg_dark" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/btn_comma" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="," android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/btn_space" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="4" android:gravity="center" android:text="space" android:textColor="#888" android:textSize="13sp" android:background="@drawable/key_bg_dark" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/btn_period" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="." android:textColor="#fff" android:textSize="16sp" android:background="@drawable/key_bg" android:layout_marginEnd="3dp"/>
        <TextView android:id="@+id/btn_enter" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.3" android:gravity="center" android:text="↵" android:textColor="#fff" android:textSize="18sp" android:background="@drawable/key_bg_action"/>
    </LinearLayout>

    <!-- BOTTOM SPACER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:background="#1e1e1e"/>

</LinearLayout>
