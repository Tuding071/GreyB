<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/emoji_root"
    android:layout_width="match_parent"
    android:layout_height="344dp"
    android:orientation="vertical"
    android:background="#1e1e1e">

    <!-- CATEGORY TAB ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/btn_clipboard"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="⧉"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:background="@drawable/key_bg_dark" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/emoji_tabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView android:id="@+id/tab_faces"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="😊"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="20sp"
                    android:background="@drawable/key_bg_dark"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/tab_people"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="👋"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="20sp"
                    android:background="@drawable/key_bg_dark"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/tab_animals"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="🐶"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="20sp"
                    android:background="@drawable/key_bg_dark"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/tab_food"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="🍕"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="20sp"
                    android:background="@drawable/key_bg_dark"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/tab_activities"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="⚽"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="20sp"
                    android:background="@drawable/key_bg_dark"
                    android:layout_marginEnd="4dp"/>

                <TextView android:id="@+id/tab_objects"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="💡"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="20sp"
                    android:background="@drawable/key_bg_dark"/>

            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/btn_tools"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✎"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:background="@drawable/key_bg_dark" />

    </LinearLayout>

    <!-- EMOJI GRID -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <GridLayout
            android:id="@+id/emoji_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="8"
            android:useDefaultMargins="true"/>

    </androidx.core.widget.NestedScrollView>

    <!-- ABC ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView android:id="@+id/btn_abc"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="ABC"
            android:textColor="#fff"
            android:textSize="14sp"
            android:background="@drawable/key_bg_dark"/>

    </LinearLayout>

    <!-- BOTTOM SPACER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:background="#1e1e1e"/>

</LinearLayout>
