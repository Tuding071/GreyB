<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clipboard_root"
    android:layout_width="match_parent"
    android:layout_height="344dp"
    android:orientation="vertical"
    android:background="#1e1e1e">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/btn_clipboard_active"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="⧉"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:background="@drawable/key_bg_accent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="Clipboard"
            android:textColor="#aaaaaa"
            android:textSize="14sp"
            android:paddingStart="12dp" />

        <TextView
            android:id="@+id/btn_clipboard_close"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✕"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:background="@drawable/key_bg_dark" />

    </LinearLayout>

    <!-- LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/clipboard_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="4dp"/>

    <!-- BOTTOM SPACER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:background="#1e1e1e"/>

</LinearLayout>
